{
  "name": "backend",
  "version": "1.0.0",
  "description": "Backend for NutriOne-ERP",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "typeorm": "typeorm",
    "migration:generate": "typeorm migration:generate -d src/config/data-source.js",
    "migration:run": "typeorm migration:run -d src/config/data-source.js",
    "migration:revert": "typeorm migration:revert -d src/config/data-source.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "pg": "^8.11.5",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  }
}
